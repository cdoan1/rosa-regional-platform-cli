{
  "data": {
    "apiVersion": "work.open-cluster-management.io/v1",
    "kind": "ManifestWork",
    "metadata": {
      "name": "test-cluster"
    },
    "spec": {
      "workload": {
        "manifests": [
          {
            "apiVersion": "hypershift.openshift.io/v1beta1",
            "kind": "HostedCluster",
            "metadata": {
              "name": "test-cluster",
